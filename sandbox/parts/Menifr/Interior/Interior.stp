GLOBAL_UNCERTAINTY_ASSIGNED_CONTEXT((#6043)) 
GLOBAL_UNIT_ASSIGNED_CONTEXT((#6040,#6041,#6042)) REPRESENTATION_CONTEXT
('Context #1','3D Context with UNIT and UNCERTAINTY') );
#6040 = ( LENGTH_UNIT() NAMED_UNIT(*) SI_UNIT(.MILLI.,.METRE.) );
#6041 = ( NAMED_UNIT(*) PLANE_ANGLE_UNIT() SI_UNIT($,.RADIAN.) );
#6042 = ( NAMED_UNIT(*) SI_UNIT($,.STERADIAN.) SOLID_ANGLE_UNIT() );
#6043 = UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(1.E-03),#6040,
  'distance_accuracy_value','confusion accuracy');
#6044 = PRODUCT_RELATED_PRODUCT_CATEGORY('part',$,(#7));
ENDSEC;
